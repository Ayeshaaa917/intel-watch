async function callClaude(messages) {
  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      tools: [{ type: "web_search_20250305", name: "web_search" }],
      messages,
    }),
  });
  if (!response.ok) {
    const err = await response.json().catch(() => ({}));
    throw new Error(err?.error?.message || `HTTP ${response.status}`);
  }
  return response.json();
}

async function fetchWithToolLoop(prompt, onStatus) {
  let messages = [{ role: "user", content: prompt }];

  for (let i = 0; i < 8; i++) {
    onStatus(`Scanning live sources... (step ${i + 1})`);
    const data = await callClaude(messages);

    const textBlocks = (data.content || []).filter(b => b.type === "text");
    const toolUseBlocks = (data.content || []).filter(b => b.type === "tool_use");

    if (data.stop_reason === "end_turn" || toolUseBlocks.length === 0) {
      const text = textBlocks.map(b => b.text).join("\n").trim();
      if (text) return text;
      throw new Error("No text returned. Please try again.");
    }

    messages.push({ role: "assistant", content: data.content });

    const toolResults = toolUseBlocks.map(block => ({
      type: "tool_result",
      tool_use_id: block.id,
      content: `Search for "${block.input?.query || "query"}" completed.`,
    }));

    messages.push({ role: "user", content: toolResults });
  }
  throw new Error("Too many search steps. Try again.");
}

function parseMarkdown(text) {
  const lines = text.split("\n");
  return lines.map((line, key) => {
    if (!line.trim()) return <div key={key} style={{ height: "0.5em" }} />;
    if (/^#{1,2} /.test(line)) {
      const content = line.replace(/^#{1,2} /, "");
      return <div key={key} style={{ color: "#ffd700", fontSize: "0.85rem", fontWeight: 700, marginTop: "1.2em", marginBottom: "0.3em", letterSpacing: "0.1em", borderBottom: "1px solid #ffd70033", paddingBottom: "4px" }}>══ {content.toUpperCase()} ══</div>;
    }
    if (line.startsWith("### ")) {
      return <div key={key} style={{ color: "#00e5ff", fontSize: "0.78rem", fontWeight: 700, marginTop: "0.9em", marginBottom: "0.2em" }}>▸ {line.replace("### ", "")}</div>;
    }
    if (line.startsWith("**") && line.endsWith("**")) {
      return <div key={key} style={{ color: "#ffd700", fontSize: "0.78rem", fontWeight: 700, marginTop: "0.7em" }}>{line.replace(/\*\*/g, "")}</div>;
    }
    if (line.startsWith("- ") || line.startsWith("* ")) {
      return <div key={key} style={{ display: "flex", gap: "8px", marginBottom: "3px", paddingLeft: "8px" }}><span style={{ color: "#00e5ff", flexShrink: 0 }}>›</span><span style={{ fontSize: "0.75rem", lineHeight: 1.7, color: "#c8d8e8" }}>{line.replace(/^[-*] /, "").replace(/\*\*(.+?)\*\*/g, "$1")}</span></div>;
    }
    if (/^\d+\. /.test(line)) {
      const num = line.match(/^(\d+)\./)[1];
      return <div key={key} style={{ display: "flex", gap: "8px", marginBottom: "3px", paddingLeft: "8px" }}><span style={{ color: "#ffd700", flexShrink: 0, minWidth: "18px", fontSize: "0.73rem" }}>{num}.</span><span style={{ fontSize: "0.75rem", lineHeight: 1.7, color: "#c8d8e8" }}>{line.replace(/^\d+\. /, "")}</span></div>;
    }
    return <div key={key} style={{ fontSize: "0.75rem", lineHeight: 1.7, color: "#c8d8e8", marginBottom: "2px" }}>{line.replace(/\*\*(.+?)\*\*/g, "$1")}</div>;
  });
}

